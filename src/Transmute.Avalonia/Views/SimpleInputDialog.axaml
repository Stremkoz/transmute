<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Transmute.Avalonia.Views.SimpleInputDialog"
        Title="Transmute" Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False" ShowInTaskbar="False"
        Background="{DynamicResource AppBackground}">
    <StackPanel Margin="16" Spacing="8">
        <TextBlock x:Name="LabelText" TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBox x:Name="InputBox" Padding="6,5" FontSize="12"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
            <Button Content="OK" Classes="primary" Width="72" FontSize="12"
                    HorizontalContentAlignment="Center"
                    IsDefault="True" Click="OK_Click"/>
            <Button Content="Cancel" Classes="secondary" Width="72" FontSize="12"
                    HorizontalContentAlignment="Center"
                    IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
