<Window x:Class="Transmute.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Transmute.GUI.ViewModels"
        mc:Ignorable="d"
        Title="Transmute — Image Converter" Height="680" Width="860"
        MinWidth="700" MinHeight="500"
        AllowDrop="True"
        Drop="Window_Drop"
        DragEnter="Window_DragEnter">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCCCCC"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C8C8C8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#D32F2F"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B71C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="160"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#1E1E2E" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="⚡ Transmute" FontSize="16" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="⚙ Settings" Style="{StaticResource SecondaryButton}"
                        Click="OpenSettings_Click" Padding="12,6"/>
            </Grid>
        </Border>

        <!-- Drop Zone / File List -->
        <Border Grid.Row="1" Margin="12,12,12,0" Background="White" CornerRadius="6"
                BorderBrush="#D0D0D0" BorderThickness="2" AllowDrop="True"
                Drop="DropZone_Drop" DragEnter="DropZone_DragEnter" DragLeave="DropZone_DragLeave">
            <Grid>
                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding InputFiles.Count, Converter={StaticResource ZeroToVisibleConverter}}">
                    <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Drop images here or click Add Files"
                               FontSize="14" Foreground="#888" HorizontalAlignment="Center"/>
                    <TextBlock Text="Supports PNG, JPEG, WEBP, AVIF, JXL, TIFF, GIF, and more"
                               FontSize="11" Foreground="#AAA" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- File list -->
                <ListView ItemsSource="{Binding InputFiles}" SelectionMode="Extended"
                          Background="Transparent" BorderThickness="0"
                          Visibility="{Binding InputFiles.Count, Converter={StaticResource NonZeroToVisibleConverter}}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="File Name" Width="320"
                                            DisplayMemberBinding="{Binding FileName}"/>
                            <GridViewColumn Header="Size" Width="80"
                                            DisplayMemberBinding="{Binding Size}"/>
                            <GridViewColumn Header="Path" Width="300"
                                            DisplayMemberBinding="{Binding Path}"/>
                            <GridViewColumn Header="" Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" Padding="4,2" FontSize="10"
                                                Style="{StaticResource DangerButton}"
                                                Command="{Binding DataContext.RemoveFileCommand,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <!-- Controls row -->
        <Border Grid.Row="2" Margin="12,10,12,0" Background="White"
                CornerRadius="6" BorderBrush="#D0D0D0" BorderThickness="1" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Format:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1" ItemsSource="{x:Static vm:MainViewModel.SupportedFormats}"
                          SelectedItem="{Binding TargetFormat}" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="3" Text="Quality:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Slider Grid.Column="4" Minimum="1" Maximum="100" Value="{Binding Quality}"
                        VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1"/>

                <TextBlock Grid.Column="6" VerticalAlignment="Center" Margin="4,0,12,0">
                    <Run Text="{Binding Quality, Mode=OneWay}"/><Run Text="%"/>
                </TextBlock>

                <CheckBox Grid.Column="7" Content="Preserve Metadata" VerticalAlignment="Center"
                          IsChecked="{Binding PreserveMetadata}"/>

                <Button Grid.Column="8" Content="+ Add Files" Style="{StaticResource SecondaryButton}"
                        Click="AddFiles_Click" Padding="10,6"/>

                <Button Grid.Column="10" Content="Clear" Style="{StaticResource SecondaryButton}"
                        Command="{Binding ClearFilesCommand}" Padding="10,6"/>

                <Button Grid.Column="12" Content="⚡ Convert" Style="{StaticResource PrimaryButton}"
                        Command="{Binding ConvertCommand}" Padding="16,6"/>
            </Grid>
        </Border>

        <!-- Log panel -->
        <Border Grid.Row="3" Margin="12,10,12,0" Background="#1E1E2E" CornerRadius="6" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="LogScrollViewer">
                <ItemsControl ItemsSource="{Binding LogLines}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="#CCCCCC" FontFamily="Consolas"
                                       FontSize="12" Margin="0,1"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="4" Background="#E8E8E8" Padding="12,6" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="12"/>
                <ProgressBar Grid.Column="1" Value="{Binding ProgressValue}" Maximum="{Binding ProgressMax}"
                             Height="8" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Content="Cancel" Style="{StaticResource DangerButton}"
                        Command="{Binding CancelCommand}" Padding="10,4"
                        Visibility="{Binding IsConverting, Converter={StaticResource BoolToVisibleConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
