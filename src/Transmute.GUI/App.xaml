<Application x:Class="Transmute.GUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Transmute.GUI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Theme colours (Light or Dark) — swapped at runtime by ThemeManager -->
                <ResourceDictionary Source="Themes/Light.xaml"/>
                <!-- Themed control styles — permanent, reference DynamicResource colours -->
                <ResourceDictionary Source="Themes/ControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters available to all windows -->
            <local:ZeroToVisibleConverter         x:Key="ZeroToVisibleConverter"/>
            <local:NonZeroToVisibleConverter      x:Key="NonZeroToVisibleConverter"/>
            <local:BoolToVisibleConverter         x:Key="BoolToVisibleConverter"/>
            <local:InverseBoolConverter           x:Key="InverseBoolConverter"/>
            <local:NullOrEmptyToVisibleConverter  x:Key="NullOrEmptyToVisibleConverter"/>
            <local:NotNullOrEmptyToVisibleConverter x:Key="NotNullOrEmptyToVisibleConverter"/>
            <local:InverseBoolToVisibleConverter  x:Key="InverseBoolToVisibleConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
