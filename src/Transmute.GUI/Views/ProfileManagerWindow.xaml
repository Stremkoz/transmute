<Window x:Class="Transmute.GUI.Views.ProfileManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Transmute — Profiles" Height="460" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Profile Manager" FontSize="15" FontWeight="SemiBold" Foreground="#1E1E2E"/>
            <TextBlock FontSize="11" Foreground="#777" TextWrapping="Wrap" Margin="0,4,0,0">
                Create and manage profiles. To edit a profile's settings, select it here,
                then open Settings — the Defaults tab will apply to the selected profile.
            </TextBlock>
        </StackPanel>

        <!-- Profile list -->
        <ListBox Grid.Row="2"
                 ItemsSource="{Binding Profiles}"
                 SelectedItem="{Binding SelectedProfile}"
                 BorderBrush="#DCDFE6" BorderThickness="1"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding}" FontSize="12" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- OnlyFormats warning banner — shown when selected profile has OnlyFormats set -->
        <Border Grid.Row="4" Background="#FFF3E0" BorderBrush="#FFA726" BorderThickness="1" CornerRadius="5"
                Padding="10,8" Visibility="{Binding SelectedProfileHasOnlyFilter,
                    Converter={StaticResource BoolToVisibleConverter}}"
                x:Name="OnlyFilterWarning">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" FontSize="13" Foreground="#E65100" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="OnlyFilterText" FontSize="11" Foreground="#BF360C"
                           TextWrapping="Wrap" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Action buttons -->
        <WrapPanel Grid.Row="6" Orientation="Horizontal">
            <Button Content="New Profile" Padding="12,6" Margin="0,0,6,0" FontSize="12"
                    Command="{Binding CreateProfileCommand}"
                    Background="#0078D4" Foreground="White" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCCCCC"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Duplicate" Padding="12,6" Margin="0,0,6,0" FontSize="12"
                    Command="{Binding DuplicateProfileCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#F0F0F0" CornerRadius="4" BorderBrush="#CCCCCC"
                                BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#F8F8F8"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Rename" Padding="12,6" Margin="0,0,6,0" FontSize="12"
                    Command="{Binding RenameProfileCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#F0F0F0" CornerRadius="4" BorderBrush="#CCCCCC"
                                BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#F8F8F8"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Delete" Padding="12,6" FontSize="12"
                    Command="{Binding DeleteProfileCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#F0F0F0" CornerRadius="4" BorderBrush="#CCCCCC"
                                BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FDECEA"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E57373"/>
                                <Setter Property="Foreground" Value="#C62828"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#F8F8F8"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </WrapPanel>

        <!-- Footer: path + close -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="📂 Open Profiles Folder" HorizontalAlignment="Left"
                    Padding="12,8" FontSize="12" Click="OpenFolder_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#F0F0F0" CornerRadius="4" BorderBrush="#CCCCCC"
                                BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="1" Content="Close"
                    Width="90" Padding="0,8" FontSize="12" IsCancel="True" Click="Close_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="#F0F0F0" CornerRadius="4" BorderBrush="#CCCCCC"
                            BorderThickness="1" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#E0E0E0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>
