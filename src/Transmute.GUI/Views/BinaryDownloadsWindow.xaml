<Window x:Class="Transmute.GUI.Views.BinaryDownloadsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Download Binaries" Height="660" Width="660"
        MinHeight="500" MinWidth="560"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource TextPrimaryBrush}">

    <Window.Resources>
        <Style x:Key="ToolName" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style x:Key="UrlText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource FolderTitleBrush}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style x:Key="NoteText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>
        <Style x:Key="OpenBtn" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Tool list -->
            <RowDefinition Height="Auto"/>   <!-- PATH instructions -->
            <RowDefinition Height="Auto"/>   <!-- Close button -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Download Binaries" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap">
                Click Open to go to each tool's official download page. After installing, use
                Auto-Detect in the Binaries tab, or paste the full path manually.
            </TextBlock>
        </StackPanel>

        <!-- Tool list -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBackground}" CornerRadius="8"
                BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- cwebp / dwebp -->
                    <Border BorderBrush="{DynamicResource RowDividerBrush}" BorderThickness="0,0,0,1" Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Style="{StaticResource ToolName}" Text="cwebp / dwebp"/>
                                <TextBlock Style="{StaticResource UrlText}" Margin="0,3,0,0"
                                           Text="developers.google.com/speed/webp/docs/precompiled"/>
                                <TextBlock Style="{StaticResource NoteText}">
                                    Download the Windows zip. Extract <Run FontWeight="SemiBold">cwebp.exe</Run>
                                    and <Run FontWeight="SemiBold">dwebp.exe</Run> to a folder like
                                    <Run FontFamily="Consolas">C:\Tools\</Run>.
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Open" Style="{StaticResource OpenBtn}"
                                    Tag="https://developers.google.com/speed/webp/docs/precompiled"
                                    Click="OpenUrl_Click"/>
                        </Grid>
                    </Border>

                    <!-- libvips -->
                    <Border BorderBrush="{DynamicResource RowDividerBrush}" BorderThickness="0,0,0,1" Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Style="{StaticResource ToolName}" Text="libvips"/>
                                <TextBlock Style="{StaticResource UrlText}" Margin="0,3,0,0"
                                           Text="github.com/libvips/libvips/releases"/>
                                <TextBlock Style="{StaticResource NoteText}">
                                    Download the <Run FontWeight="SemiBold">Windows</Run> binary
                                    (<Run FontFamily="Consolas">vips-dev-w64-all-*.zip</Run>). Unlike the other
                                    tools, vips.exe must stay beside its DLLs — extract the entire
                                    <Run FontFamily="Consolas">bin\</Run> folder to something like
                                    <Run FontFamily="Consolas">C:\Tools\vips\</Run>, so the path to the exe
                                    becomes <Run FontFamily="Consolas">C:\Tools\vips\vips.exe</Run>.
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Open" Style="{StaticResource OpenBtn}"
                                    Tag="https://github.com/libvips/libvips/releases"
                                    Click="OpenUrl_Click"/>
                        </Grid>
                    </Border>

                    <!-- cjxl / djxl -->
                    <Border BorderBrush="{DynamicResource RowDividerBrush}" BorderThickness="0,0,0,1" Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Style="{StaticResource ToolName}" Text="cjxl / djxl"/>
                                <TextBlock Style="{StaticResource UrlText}" Margin="0,3,0,0"
                                           Text="github.com/libjxl/libjxl/releases"/>
                                <TextBlock Style="{StaticResource NoteText}">
                                    Download the Windows zip. Extract <Run FontWeight="SemiBold">cjxl.exe</Run>
                                    and <Run FontWeight="SemiBold">djxl.exe</Run> to a folder like
                                    <Run FontFamily="Consolas">C:\Tools\</Run>.
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Open" Style="{StaticResource OpenBtn}"
                                    Tag="https://github.com/libjxl/libjxl/releases"
                                    Click="OpenUrl_Click"/>
                        </Grid>
                    </Border>

                    <!-- ffmpeg -->
                    <Border BorderBrush="{DynamicResource RowDividerBrush}" BorderThickness="0,0,0,1" Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Style="{StaticResource ToolName}" Text="ffmpeg"/>
                                <TextBlock Style="{StaticResource UrlText}" Margin="0,3,0,0"
                                           Text="ffmpeg.org/download.html"/>
                                <TextBlock Style="{StaticResource NoteText}">
                                    Choose a Windows build (gyan.dev or BtbN are recommended).
                                    Extract <Run FontWeight="SemiBold">ffmpeg.exe</Run> from the
                                    <Run FontFamily="Consolas">bin\</Run> folder to
                                    <Run FontFamily="Consolas">C:\Tools\</Run>.
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Open" Style="{StaticResource OpenBtn}"
                                    Tag="https://ffmpeg.org/download.html"
                                    Click="OpenUrl_Click"/>
                        </Grid>
                    </Border>

                    <!-- ImageMagick -->
                    <Border Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Style="{StaticResource ToolName}" Text="ImageMagick"/>
                                <TextBlock Style="{StaticResource UrlText}" Margin="0,3,0,0"
                                           Text="imagemagick.org/download"/>
                                <TextBlock Style="{StaticResource NoteText}">
                                    Use the Windows installer — it handles PATH automatically.
                                    The exe will be named <Run FontWeight="SemiBold">magick.exe</Run>.
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Open" Style="{StaticResource OpenBtn}"
                                    Tag="https://imagemagick.org/download/#gsc.tab=0"
                                    Click="OpenUrl_Click"/>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- PATH instructions -->
        <Border Grid.Row="2" Margin="0,10,0,0" Background="{DynamicResource ToolbarBackground}" CornerRadius="8" Padding="16,12">
            <StackPanel>
                <TextBlock Text="Adding to PATH (for Auto-Detect)" FontSize="12" FontWeight="SemiBold"
                           Foreground="#7C83FD" Margin="0,0,0,6"/>
                <TextBlock FontSize="11" Foreground="#C8C8D4" TextWrapping="Wrap" LineHeight="18">
                    <Run FontWeight="SemiBold" Foreground="White">Win + S</Run>
                    <Run Foreground="#AAA"> → search </Run>
                    <Run FontFamily="Consolas" Foreground="#7C83FD">Environment Variables</Run>
                    <Run Foreground="#AAA"> → </Run>
                    <Run FontWeight="SemiBold" Foreground="White">Edit the system environment variables</Run>
                    <Run Foreground="#AAA"> → </Run>
                    <Run FontWeight="SemiBold" Foreground="White">Environment Variables…</Run>
                    <Run Foreground="#AAA"> → under </Run>
                    <Run FontWeight="SemiBold" Foreground="White">System variables</Run>
                    <Run Foreground="#AAA">, select </Run>
                    <Run FontFamily="Consolas" Foreground="#7C83FD">Path</Run>
                    <Run Foreground="#AAA"> → </Run>
                    <Run FontWeight="SemiBold" Foreground="White">Edit → New</Run>
                    <Run Foreground="#AAA">.</Run>
                </TextBlock>
                <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="#C8C8D4" TextWrapping="Wrap" LineHeight="18">
                    <Run Foreground="#AAA">Add </Run>
                    <Run FontFamily="Consolas" Foreground="#98D8A0">C:\Tools</Run>
                    <Run Foreground="#AAA"> for single EXEs (cwebp, cjxl, ffmpeg, magick), or </Run>
                    <Run FontFamily="Consolas" Foreground="#98D8A0">C:\Tools\vips</Run>
                    <Run Foreground="#AAA"> for libvips. Click OK on all dialogs, then use Auto-Detect above.</Run>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Close -->
        <Button Grid.Row="3" Content="Close" HorizontalAlignment="Right" Margin="0,10,0,0"
                Padding="16,7" Click="Close_Click"/>
    </Grid>
</Window>
