<Window x:Class="Transmute.GUI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Transmute Settings" Height="600" Width="640"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Window.Resources>
        <!-- Segmented toggle button used in the filter Skip/Only pill -->
        <Style x:Key="FilterSegment" TargetType="ToggleButton">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="9,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding Tag}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E3F2FD"/>
                                <Setter Property="Foreground" Value="#0078D4"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0F4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="130"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="PathBox" TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="0">
            <!-- Binaries Tab -->
            <TabItem Header="Binaries">
                <ScrollViewer Margin="16" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Backend Binary Paths"/>
                        <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,10">
                            Leave blank to auto-detect from system PATH. Enter a full path to override.
                        </TextBlock>

                        <!-- cwebp -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource Label}" Text="cwebp"/>
                            <TextBox Grid.Column="1" Style="{StaticResource PathBox}"
                                     Text="{Binding CwebpPath, UpdateSourceTrigger=PropertyChanged}"
                                     />
                        </Grid>

                        <!-- dwebp -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource Label}" Text="dwebp"/>
                            <TextBox Grid.Column="1" Style="{StaticResource PathBox}"
                                     Text="{Binding DwebpPath, UpdateSourceTrigger=PropertyChanged}"
                                     />
                        </Grid>

                        <!-- cjxl -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource Label}" Text="cjxl"/>
                            <TextBox Grid.Column="1" Style="{StaticResource PathBox}"
                                     Text="{Binding CjxlPath, UpdateSourceTrigger=PropertyChanged}"
                                     />
                        </Grid>

                        <!-- djxl -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource Label}" Text="djxl"/>
                            <TextBox Grid.Column="1" Style="{StaticResource PathBox}"
                                     Text="{Binding DjxlPath, UpdateSourceTrigger=PropertyChanged}"
                                     />
                        </Grid>

                        <!-- ffmpeg -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource Label}" Text="ffmpeg"/>
                            <TextBox Grid.Column="1" Style="{StaticResource PathBox}"
                                     Text="{Binding FfmpegPath, UpdateSourceTrigger=PropertyChanged}"
                                     />
                        </Grid>

                        <!-- magick -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource Label}" Text="magick"/>
                            <TextBox Grid.Column="1" Style="{StaticResource PathBox}"
                                     Text="{Binding MagickPath, UpdateSourceTrigger=PropertyChanged}"
                                     />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="Auto-Detect All from PATH" Padding="12,6"
                                    Command="{Binding AutoDetectAllCommand}"/>
                            <Button Content="⬇ Download Binaries" Padding="12,6" Margin="8,0,0,0"
                                    Command="{Binding DownloadBinariesCommand}"
                                    Background="#E8F4FD" BorderBrush="#90CAF9" BorderThickness="1"/>
                        </StackPanel>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="Config File Location" Margin="0,20,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Mode:" FontSize="11" Foreground="#666" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding ConfigMode}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#0D47A1" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBox IsReadOnly="True" Style="{StaticResource PathBox}"
                                 Text="{Binding ConfigFilePath, Mode=OneWay}" Background="#F0F0F0"/>
                        <TextBlock FontSize="10" Foreground="#888" TextWrapping="Wrap" Margin="0,4,0,0">
                            To use portable mode: place a file named "portable" (no extension) beside the exe,
                            or copy config.json there. Transmute will use that file instead of AppData.
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Processing Tab -->
            <TabItem Header="Processing">
                <StackPanel Margin="16">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Parallel Processing"/>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="Max parallel jobs"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Slider Minimum="0" Maximum="32" Value="{Binding MaxParallelJobs}"
                                    Width="200" VerticalAlignment="Center" IsSnapToTickEnabled="True"/>
                            <TextBlock VerticalAlignment="Center" Margin="8,0,0,0">
                                <Run Text="{Binding MaxParallelJobs, Mode=OneWay}"/>
                                <Run Text=" (0 = auto)"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="libvips threads"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Slider Minimum="0" Maximum="32" Value="{Binding VipsConcurrency}"
                                    Width="200" VerticalAlignment="Center" IsSnapToTickEnabled="True"/>
                            <TextBlock VerticalAlignment="Center" Margin="8,0">
                                <Run Text="{Binding VipsConcurrency, Mode=OneWay}"/>
                                <Run Text=" (0 = uncapped)"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                    <TextBlock FontSize="11" Foreground="#888" TextWrapping="Wrap" Margin="150,2,0,0">
                        libvips will use every available core if uncapped. 2–4 is a good limit
                        when running multiple parallel jobs.
                    </TextBlock>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Temp Directory" Margin="0,16,0,6"/>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="Temp directory"/>
                        <TextBox Grid.Column="1" Style="{StaticResource PathBox}"
                                 Text="{Binding TempDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 />
                    </Grid>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Log File" Margin="0,16,0,4"/>
                    <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,8">
                        After each conversion, write a log file beside the output images.
                        Disabled by default.
                    </TextBlock>
                    <CheckBox Content="Write log file after conversion"
                              IsChecked="{Binding LogEnabled}" Margin="0,0,0,8"/>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="Log format"
                                   IsEnabled="{Binding LogEnabled}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    IsEnabled="{Binding LogEnabled}">
                            <Border BorderBrush="#BBBBBB" BorderThickness="1" CornerRadius="4"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton Content=".log  (text)" Style="{StaticResource FilterSegment}"
                                                  IsChecked="{Binding LogFormatIsJson,
                                                      Converter={StaticResource InverseBoolConverter}}"
                                                  Tag="4,0,0,0"/>
                                    <Rectangle Width="1" Fill="#BBBBBB" VerticalAlignment="Stretch"/>
                                    <ToggleButton Content=".json" Style="{StaticResource FilterSegment}"
                                                  IsChecked="{Binding LogFormatIsJson}"
                                                  Tag="0,0,4,0"/>
                                </StackPanel>
                            </Border>
                            <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" FontSize="11" Foreground="#666">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Human-readable text file"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LogFormatIsJson}" Value="True">
                                                <Setter Property="Text" Value="Structured JSON — good for scripts and CLI"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </TabItem>

            <!-- Defaults Tab -->
            <TabItem Header="Defaults">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">

                    <!-- Profile selector at top of Defaults tab -->
                    <Border Background="#F0F4FF" BorderBrush="#7C83FD" BorderThickness="1" CornerRadius="6"
                            Padding="12,8" Margin="0,0,0,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Editing profile:" FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Foreground="#1E1E2E" Margin="0,0,10,0"/>
                                <ComboBox ItemsSource="{Binding Profiles}"
                                          SelectedItem="{Binding SelectedProfile}"
                                          MinWidth="160" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="11" Foreground="#555" Margin="0,6,0,0" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Changes below will save to this profile's file. Binaries and Processing always use global settings."/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDefaultProfile}" Value="True">
                                                <Setter Property="Text" Value="Changes below will save to global defaults. To edit a profile, select it from the dropdown above."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Default Quality"/>

                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="WebP quality"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Slider Minimum="1" Maximum="100" Value="{Binding WebpQuality}" Width="200" VerticalAlignment="Center" IsSnapToTickEnabled="True"/>
                            <TextBlock VerticalAlignment="Center" Margin="8,0"><Run Text="{Binding WebpQuality, Mode=OneWay}"/><Run Text="%"/></TextBlock>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="JPEG quality"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Slider Minimum="1" Maximum="100" Value="{Binding JpegQuality}" Width="200" VerticalAlignment="Center" IsSnapToTickEnabled="True"/>
                            <TextBlock VerticalAlignment="Center" Margin="8,0"><Run Text="{Binding JpegQuality, Mode=OneWay}"/><Run Text="%"/></TextBlock>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="JXL quality"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Slider Minimum="1" Maximum="100" Value="{Binding JxlQuality}" Width="200" VerticalAlignment="Center" IsSnapToTickEnabled="True"/>
                            <TextBlock VerticalAlignment="Center" Margin="8,0"><Run Text="{Binding JxlQuality, Mode=OneWay}"/><Run Text="%"/></TextBlock>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="AVIF quality"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Slider Minimum="1" Maximum="100" Value="{Binding AvifQuality}" Width="200" VerticalAlignment="Center" IsSnapToTickEnabled="True"/>
                            <TextBlock VerticalAlignment="Center" Margin="8,0"><Run Text="{Binding AvifQuality, Mode=OneWay}"/><Run Text="%"/></TextBlock>
                        </StackPanel>
                    </Grid>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Compression Effort" Margin="0,16,0,4"/>
                    <TextBlock FontSize="11" Foreground="#666" Margin="0,0,0,8" TextWrapping="Wrap">
                        Higher effort = smaller files but slower encoding.
                    </TextBlock>

                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="WebP method"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Slider Minimum="0" Maximum="6" Value="{Binding WebpMethod}" Width="200" VerticalAlignment="Center" IsSnapToTickEnabled="True"/>
                            <TextBlock VerticalAlignment="Center" Margin="8,0">
                                <Run Text="{Binding WebpMethod, Mode=OneWay}"/>
                                <Run Text=" / 6"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="JXL effort"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Slider Minimum="1" Maximum="9" Value="{Binding JxlEffort}" Width="200" VerticalAlignment="Center" IsSnapToTickEnabled="True"/>
                            <TextBlock VerticalAlignment="Center" Margin="8,0">
                                <Run Text="{Binding JxlEffort, Mode=OneWay}"/>
                                <Run Text=" / 9"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Behavior" Margin="0,16,0,6"/>
                    <CheckBox Content="Preserve metadata (EXIF, ICC, XMP)" IsChecked="{Binding PreserveMetadata}" Margin="0,4"/>
                    <CheckBox Content="Overwrite existing files" IsChecked="{Binding OverwriteExisting}" Margin="0,4"/>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Lossless Default" Margin="0,16,0,4"/>
                    <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,8">
                        Applies to formats that support it (JXL, WebP). Can be overridden per session in the main window.
                    </TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="Lossless" IsChecked="{Binding LosslessDefault}"
                                     Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <RadioButton Content="Lossy (quality-based)"
                                     IsChecked="{Binding LosslessDefault, Converter={StaticResource InverseBoolConverter}}"
                                     VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Output Naming Pattern" Margin="0,16,0,4"/>
                    <TextBlock FontSize="11" Foreground="#666" Margin="0,0,0,6" TextWrapping="Wrap">
                        Tokens: {name} = filename without extension,  {ext} = target format,
                        {original_ext} = source extension,  {date} = yyyyMMdd,
                        {counter} = auto-padded sequence number (e.g. 001, 002… for a 100+ file batch)
                    </TextBlock>
                    <TextBox Style="{StaticResource PathBox}"
                             Text="{Binding OutputNamingPattern, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Default Output Folder" Margin="0,16,0,4"/>
                    <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,6">
                        Where converted files are saved by default. Leave empty to save beside the source file.
                        Can be overridden per session in the main window.
                    </TextBlock>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource PathBox}"
                                 Text="{Binding DefaultOutputDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="Browse…" Style="{StaticResource Btn}"
                                Click="BrowseDefaultOutput_Click"/>
                        <Button Grid.Column="2" Content="Clear" Style="{StaticResource Btn}"
                                Click="ClearDefaultOutput_Click"/>
                    </Grid>

                    <!-- Input format filter — named profiles only; hidden for Default -->
                    <StackPanel Visibility="{Binding IsDefaultProfile,
                                    Converter={StaticResource InverseBoolToVisibleConverter}}">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Input Format Filter" Margin="0,16,0,4"/>
                        <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,8">
                            Restrict which input formats this profile acts on. Leave empty to process everything.
                            Comma-separated extensions, e.g. <Run FontFamily="Consolas">jpg, png</Run>
                        </TextBlock>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Skip / Only segmented pill -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border BorderBrush="#BBBBBB" BorderThickness="1" CornerRadius="4"
                                        VerticalAlignment="Center" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <ToggleButton Content="Skip" Style="{StaticResource FilterSegment}"
                                                      IsChecked="{Binding ProfileFilterIsOnly,
                                                          Converter={StaticResource InverseBoolConverter}}"
                                                      Tag="4,0,0,0"/>
                                        <Rectangle Width="1" Fill="#BBBBBB" VerticalAlignment="Stretch"/>
                                        <ToggleButton Content="Only" Style="{StaticResource FilterSegment}"
                                                      IsChecked="{Binding ProfileFilterIsOnly}"
                                                      Tag="0,0,4,0"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="formats:" VerticalAlignment="Center" FontSize="12" Foreground="#555"/>
                            </StackPanel>

                            <TextBox Grid.Column="1" Style="{StaticResource PathBox}"
                                     Text="{Binding ProfileFormatFilter, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock FontSize="10" Foreground="#888" Margin="150,3,0,0">
                            Enter extension names without dots. Empty = no filter (all formats processed).
                        </TextBlock>
                    </StackPanel>

                </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Footer buttons -->
        <Border Grid.Row="1" Background="#F0F0F0" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" Content="Reset to Defaults" Padding="12,6"
                        Command="{Binding ResetDefaultsCommand}"/>
                <Button Grid.Column="3" Content="Save" Padding="16,6"
                        Command="{Binding SaveCommand}" Background="#0078D4" Foreground="White"
                        BorderThickness="0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
